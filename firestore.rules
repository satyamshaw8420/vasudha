rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() { return request.auth != null; }
    function isOwner(uid) { return request.auth.uid == uid; }
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid))
        .data.role == 'admin';
    }
    function isAgent() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid))
        .data.role == 'agent';
    }

    match /users/{uid} {
      allow read: if isAuth() && (isOwner(uid) || isAdmin());
      allow write: if isAuth() && isOwner(uid);
    }
    match /wasteLogs/{logId} {
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid || isAdmin() || isAgent()
      );
      allow create: if isAuth();
      allow update: if isAdmin() || isAgent();
    }
    match /pickups/{pickupId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAdmin() || isAgent();
    }
    match /credits/{uid} {
      allow read: if isAuth() && isOwner(uid);
      allow write: if false; // Only Functions can write credits
    }
    match /qrCodes/{qrId} {
      allow read: if isAuth();
      allow write: if false; // Only Functions can write QR codes
    }
  }
}
